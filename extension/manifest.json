{
  "manifest_version": 3,
  "name": "Prism",
  "version": "0.1.0",
  "description": "Route Claude through Prism for deterministic semantic routing and filler stripping.",
  "permissions": ["storage", "tabs", "declarativeNetRequest"],
  "host_permissions": ["https://claude.ai/*", "http://localhost:3179/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["page-bridge.js"],
      "matches": ["https://claude.ai/*"]
    }
  ],
  "action": {
    "default_title": "Prism",
    "default_popup": "popup.html"
  }
}
