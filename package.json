{
  "name": "prism-ai",
  "version": "0.1.0",
  "description": "Zero-token semantic routing for Claude. Right knowledge. Right context. Every time.",
  "license": "MIT",
  "type": "commonjs",
  "main": "dist/index.js",
  "source": "src/index.ts",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "source": "./src/index.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "prism": "bin/prism.js"
  },
  "files": [
    "bin",
    "dist",
    "src",
    "rules",
    "extension",
    ".env.example",
    "README.md",
    "SDK.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "dev": "ts-node src/cli/index.ts start",
    "start": "node bin/prism.js start",
    "status": "node bin/prism.js status",
    "dry-run": "node bin/prism.js test \"what is the capital of India\"",
    "test": "npm run build && jest --runInBand"
  },
  "keywords": [
    "anthropic",
    "claude",
    "proxy",
    "routing",
    "bm25",
    "knowledge-graph",
    "typescript"
  ],
  "dependencies": {
    "chalk": "^5.3.0",
    "chokidar": "^3.6.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "glob": "^10.4.5",
    "http-proxy-middleware": "^3.0.0",
    "js-yaml": "^4.1.0",
    "natural": "^6.12.0",
    "tiktoken": "^1.0.16"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/natural": "^5.0.5",
    "@types/node": "^22.10.2",
    "jest": "^29.7.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=18.18.0"
  }
}
